  "recetas": [
    {
      "id": "rec-1",
      "title": "Ensalada de Tomate y Albahaca",
      "description": "Una receta fresca y sencilla utilizando tomates cherry de la feria.",
      "ingredients": [
        "Tomates cherry",
        "Albahaca fresca",
        "Aceite de oliva",
        "Sal y pimienta"
      ],
      "steps": [
        "Lavá y cortá los tomates cherry a la mitad.",
        "Deshojá la albahaca y cortala en trozos grandes.",
        "Mezclá los tomates y la albahaca en un tazón.",
        "Aliñá con abundante aceite de oliva extra virgen.",
        "Añadí sal y pimienta al gusto antes de servir.",
        "Sal"
      ],
      "difficulty": "Fácil",
      "time": "10 min"
    },
    {
      "id": "rec-2",
      "title": "Brócoli Salteado con Ajo",
      "description": "Brócoli crujiente salteado con ajo picado y un toque de limón.",
      "ingredients": [
        "Brócoli fresco",
        "Ajos (3 dientes)",
        "Limón de la feria",
        "Pimienta negra"
      ],
      "steps": [
        "Cortá el brócoli en ramilletes pequeños y lavalo bien.",
        "Picá los ajos finamente.",
        "En una sartén caliente con aceite, dorá los ajos por 1 minuto.",
        "Agregá el brócoli y salteá a fuego medio-alto por 5-7 minutos.",
        "Terminá con un chorrito de jugo de limón fresco y pimienta."
      ],
      "difficulty": "Fácil",
      "time": "15 min"
    }
  ],
